{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Information about a product.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "brand": { "type": "string" },
        "categoryId": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "specifications": { "type": "object" },
        "images": { "type": "array", "items": { "type": "string" } },
        "availability": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "brand", "categoryId", "description", "images", "availability", "isFeatured", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer inquiry or contact request.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["general", "expert_consultation"] },
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "productId": { "type": "string" },
        "product": { "type": "string" },
        "productName": { "type": "string" },
        "message": { "type": "string" },
        "date": { "type": "string" },
        "timeSlot": { "type": "string" },
        "consultationType": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "replied", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "mobile", "email", "message", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Administrator user.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Collection of products."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Collection of product categories."
    },
    "/inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/Inquiry" },
      "description": "Collection of customer inquiries."
    },
    "/admins/{userId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Collection of admin users."
    }
  }
}
